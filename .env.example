NEXT_PUBLIC_HALO_CHAIN_ID=84532
NEXT_PUBLIC_HALO_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_HALO_MONTHLY_CAP_USDC=100

# Public delegate address used in the browser permission request. For the current 1Shot flow,
# this should match ONESHOT_RELAYER_TARGET_WALLET_ADDRESS; Halo does not hold this private key.
NEXT_PUBLIC_HALO_SESSION_ACCOUNT_ADDRESS=

# Step 9 Base Sepolia deployment. Never commit a real private key.
BASE_SEPOLIA_RPC_URL=
BASE_SEPOLIA_PRIVATE_KEY=
HALO_BASE_SEPOLIA_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
HALO_VENICE_PAYMASTER_ADDRESS=
HALO_ALLOWED_TARGET_ENFORCER=
HALO_ERC20_TRANSFER_RECIPIENT_ENFORCER=
HALO_ERC20_SPEND_LIMIT_ENFORCER=

# Optional: set these if verifier/treasurer agent contracts or session accounts are already deployed.
HALO_VERIFIER_AGENT_ADDRESS=
HALO_TREASURER_AGENT_ADDRESS=

# Step 7 Venice verifier knobs. Real wallet auth is provided at request time, not stored here.
VENICE_API_BASE_URL=https://api.venice.ai/api/v1
VENICE_VISION_MODEL=mistral-31-24b

# Step 11-13 MetaMask/1Shot live estimate handoff.
# Keep HALO_METAMASK_PERMISSION_CONTEXT local-only; do not post it in public recordings.
HALO_METAMASK_PERMISSION_CONTEXT=
# Step 17 dependency preflight. Keep full grant JSON local-only; it can include the raw context.
HALO_METAMASK_PERMISSION_GRANT_JSON=
# JSON array or comma-separated tx hashes returned after deploying MetaMask grant dependencies through /donor.
HALO_METAMASK_DEPENDENCY_TXS=
ONESHOT_RELAYER_RPC_URL=https://relayer.1shotapi.dev/relayers
ONESHOT_API_KEY=
# 1Shot live estimates may require the first delegation delegate to match this relayer target wallet.
ONESHOT_RELAYER_TARGET_WALLET_ADDRESS=
# Used for live estimate/send rehearsals. Step 18 blocks if this planned fee does not
# match the estimate-returned requiredPaymentAmount exactly.
HALO_ONESHOT_ESTIMATE_MOCK_FEE_USDC=0.01
# Step 16 diagnostics: fee_and_grant is the normal path; fee_only isolates 1Shot fee simulation.
HALO_ONESHOT_ESTIMATE_SCENARIO=fee_and_grant
HALO_STEP16_GRANT_USDC=25
HALO_STEP18_GRANT_USDC=25
HALO_STEP19_GRANT_USDC=25
# Required before HALO_ONESHOT_LIVE=1 in Step 19. Use a real Base Sepolia test recipient.
HALO_STEP19_REQUESTER_ADDRESS=
HALO_STEP19_STATUS_POLL=1
HALO_STEP19_STATUS_POLL_ATTEMPTS=4
HALO_STEP19_STATUS_POLL_INTERVAL_MS=2500
HALO_STEP20_GRANT_USDC=1
# Optional override; defaults to HALO_STEP19_REQUESTER_ADDRESS.
HALO_STEP20_REQUESTER_ADDRESS=
HALO_STEP20_STATUS_POLL=1
HALO_STEP20_STATUS_POLL_ATTEMPTS=4
HALO_STEP20_STATUS_POLL_INTERVAL_MS=2500
HALO_STEP20_BALANCE_WAIT_MS=6000
ONESHOT_WEBHOOK_PUBLIC_KEY=
ONESHOT_WEBHOOK_SIGNATURE_REQUIRED=0
HALO_ONESHOT_ESTIMATE_LIVE=0
HALO_ONESHOT_ESTIMATE_RESULT=
HALO_ONESHOT_LIVE=0
